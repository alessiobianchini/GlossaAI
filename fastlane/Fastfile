default_platform(:ios)

PROJECT_SPEC = "src/GlossaAI.iOS/project.yml"
PROJECT_FILE = "src/GlossaAI.iOS/GlossaAI.xcodeproj"

platform :ios do
  desc "Build and upload a TestFlight build"
  lane :beta do
    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: Base64.decode64(ENV.fetch("APP_STORE_CONNECT_API_KEY_BASE64")),
      duration: 1200,
      in_house: false
    )

    sh("xcodegen generate --spec ../#{PROJECT_SPEC}")

    build_number = ENV["GITHUB_RUN_NUMBER"] || Time.now.utc.strftime("%Y%m%d%H%M%S")
    increment_build_number(
      xcodeproj: "../#{PROJECT_FILE}",
      build_number: build_number
    )

    match(
      api_key: api_key,
      type: "appstore",
      readonly: false, # Creerà i certificati se non esistono
      app_identifier: [ENV.fetch("APP_IDENTIFIER")],
      git_basic_authorization: ENV.fetch("MATCH_GIT_BASIC_AUTHORIZATION")
    )

    build_app(
      project: "../#{PROJECT_FILE}",
      scheme: "GlossaAI",
      clean: true,
      export_method: "app-store",
      xcargs: [
        "CODE_SIGN_STYLE=Manual",
        "DEVELOPMENT_TEAM=#{ENV.fetch("APPLE_DEVELOPER_TEAM_ID")}",
        "CODE_SIGN_IDENTITY='Apple Distribution'",
        "PROVISIONING_PROFILE_SPECIFIER=\"match AppStore #{ENV.fetch("APP_IDENTIFIER")}\"",
        "IPHONEOS_DEPLOYMENT_TARGET=17.0"
      ].join(" ")
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
