<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GlossaAI.Desktop.App"
             xmlns:local="using:GlossaAI.Desktop"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <Color x:Key="BackgroundDefault">#0B0F19</Color>
        <Color x:Key="BackgroundCard">#151C2C</Color>
        <Color x:Key="AccentGreen">#059669</Color>
        <Color x:Key="AccentBlue">#2563EB</Color>
        <Color x:Key="TextPrimary">#F8FAFC</Color>
        <Color x:Key="TextSecondary">#94A3B8</Color>
        <Color x:Key="AccentRed">#DC2626</Color>

        <SolidColorBrush x:Key="BackgroundDefaultBrush" Color="{StaticResource BackgroundDefault}"/>
        <SolidColorBrush x:Key="BackgroundCardBrush" Color="{StaticResource BackgroundCard}"/>
        <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}"/>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRed}"/>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontFamily" Value="Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontFamily" Value="Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Border">
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Window">
            <Setter Property="FontFamily" Value="Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Application.Styles>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/glossa-logo.ico" ToolTipText="GlossaAI Meeting Assistant" Clicked="OnShowApplicationClick">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Mostra Dashboard" Click="OnShowApplicationClick"/>
                        <NativeMenuItem Header="Avvia Registrazione" Click="OnStartRecordingClick"/>
                        <NativeMenuItem Header="Ferma Registrazione" Click="OnStopRecordingClick"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="Esci" Click="OnExitClick"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>