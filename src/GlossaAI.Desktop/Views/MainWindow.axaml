<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GlossaAI.Desktop.ViewModels"
        xmlns:models="using:GlossaAI.Core.Domain.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        WindowStartupLocation="CenterScreen"
        x:Class="GlossaAI.Desktop.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/glossa-logo.ico"
        Title="GlossaAI - Meeting Assistant"
        Background="Transparent"
        Width="1150"
        Height="750"
        MinWidth="900"
        MinHeight="650"
        CanResize="True">

    <Window.Styles>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{StaticResource AccentGreenBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#047857"/>
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="{StaticResource AccentRedBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#B91C1C"/>
        </Style>

        <Style Selector="Button.neutral">
            <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.neutral:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8"/>
        </Style>

        <Style Selector="Button.nav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="Button.nav.active /template/ ContentPresenter">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.action">
            <Setter Property="Background" Value="{StaticResource BackgroundCardBrush}"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.action:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E293B"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Styles>

    <Grid>
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial BackgroundSource="Digger" TintColor="{StaticResource BackgroundDefault}" TintOpacity="0.9" MaterialOpacity="0.8"/>
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <Grid RowDefinitions="Auto, Auto, *">
            <!-- ── TOP NAVIGATION BAR ── -->
            <Border Grid.Row="0" Background="{StaticResource BackgroundCardBrush}" BorderThickness="0,0,0,1" BorderBrush="#1E293B">
                <Grid ColumnDefinitions="Auto, *, Auto" Margin="24,14,24,14">
                    
                    <!-- Branding -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Image Source="/Assets/glossa-logo.png" Width="38" Height="38" Stretch="Uniform" VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="GlossaAI" FontWeight="Bold" FontSize="19" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="MEETING ASSISTANT" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" LetterSpacing="1.5"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Navigation Links -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Classes="nav" Classes.active="{Binding IsRecorderVisible}" Command="{Binding SwitchTabCommand}" CommandParameter="0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="🎙️" VerticalAlignment="Center"/>
                                <TextBlock Text="Recorder" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="nav" Classes.active="{Binding IsHistoryVisible}" Command="{Binding SwitchTabCommand}" CommandParameter="1">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="📚" VerticalAlignment="Center"/>
                                <TextBlock Text="Recorded" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Settings Nav -->
                    <Button Grid.Column="2" Classes="nav" Classes.active="{Binding IsSettingsVisible}" Command="{Binding SwitchTabCommand}" CommandParameter="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="⚙️" VerticalAlignment="Center"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ── UPDATE NOTIFICATION BANNER ── -->
            <Border Grid.Row="1" Background="{StaticResource AccentBlueBrush}" Padding="16,12" 
                    IsVisible="{Binding IsUpdateAvailable}">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="🚀" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding NewVersionName, StringFormat='A new version ({0}) is available!'}" 
                                   Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Downloading..." IsVisible="{Binding IsDownloadingUpdate}" 
                                   Foreground="#BFDBFE" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                        <ProgressBar IsVisible="{Binding IsDownloadingUpdate}" Value="{Binding DownloadProgress}" 
                                     Minimum="0" Maximum="100" Width="150" Height="6" CornerRadius="3" 
                                     Foreground="White" Background="#1D4ED8" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Update Now" Command="{Binding StartUpdateCommand}" 
                            IsVisible="{Binding !IsDownloadingUpdate}"
                            Background="White" Foreground="{StaticResource AccentBlueBrush}" 
                            FontWeight="Bold" CornerRadius="6" Padding="16,8"/>
                </Grid>
            </Border>

            <!-- ── MAIN CONTENT AREA ── -->
            <Grid Grid.Row="2" Margin="24">

                <!-- 1. RECORDER VIEW -->
                <Grid IsVisible="{Binding IsRecorderVisible}" RowDefinitions="Auto, *">
                    <!-- Actions Toolbar -->
                    <Border Grid.Row="0" Background="{StaticResource BackgroundCardBrush}" BorderBrush="#1E293B" BorderThickness="1"
                            CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="ACTIONS" FontSize="10" FontWeight="Bold" Foreground="#64748B"
                                       LetterSpacing="1.2" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Classes="action" Command="{Binding ExportTranscriptionCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="📄"/><TextBlock Text="Export Script"/></StackPanel>
                            </Button>
                            <Button Classes="action" Command="{Binding ExportAiRecapCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="🗒️"/><TextBlock Text="Export Recap"/></StackPanel>
                            </Button>
                            <Separator Width="1" Background="#1E293B" Margin="8,0"/>
                            <Button Classes="action" Command="{Binding TranslateRecapCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="🌐"/><TextBlock Text="Translate"/></StackPanel>
                            </Button>
                            <Button Classes="action" Command="{Binding ExportTranslationCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="💾"/><TextBlock Text="Export Translation"/></StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" ColumnDefinitions="300, 24, *">
                        <!-- Controls -->
                        <Grid Grid.Column="0" RowDefinitions="Auto, Auto, Auto, Auto">
                            <Border Grid.Row="0" Background="{StaticResource BackgroundCardBrush}" BorderBrush="#1E293B" BorderThickness="1"
                                    CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="RECORDER STATUS" FontSize="11" FontWeight="Bold" Foreground="#64748B" LetterSpacing="1"/>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                                            <Ellipse.Styles>
                                                <Style Selector="Ellipse"><Setter Property="Fill" Value="#475569"/></Style>
                                                <Style Selector="Ellipse.Recording">
                                                    <Setter Property="Fill" Value="#EF4444"/>
                                                    <Style.Animations>
                                                        <Animation Duration="0:0:1.5" IterationCount="Infinite">
                                                            <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                                            <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.3"/></KeyFrame>
                                                            <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                                        </Animation>
                                                    </Style.Animations>
                                                </Style>
                                            </Ellipse.Styles>
                                            <Classes.Recording>
                                                <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                                    <Binding Path="IsRecording"/>
                                                </MultiBinding>
                                            </Classes.Recording>
                                        </Ellipse>
                                        <TextBlock Text="{Binding StatusText}" FontSize="14" Foreground="#E2E8F0" FontWeight="Medium" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ProgressBar IsIndeterminate="True" Height="4" IsVisible="{Binding IsProcessing}" Foreground="#0D9488" Background="#1E293B"/>
                                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#F87171" TextWrapping="Wrap"
                                               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Background="{StaticResource BackgroundCardBrush}" BorderBrush="#1E293B" BorderThickness="1"
                                    CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                <StackPanel Spacing="16">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBlock Grid.Column="0" Text="AUDIO SOURCES" FontSize="11" FontWeight="Bold" Foreground="#64748B" LetterSpacing="1" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Command="{Binding RefreshDevicesCommand}" Background="Transparent" Padding="4">
                                            <TextBlock Text="🔄" FontSize="14"/>
                                        </Button>
                                    </Grid>
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Microphone" FontSize="12" Foreground="#94A3B8"/>
                                        <ComboBox ItemsSource="{Binding Microphones}" SelectedItem="{Binding SelectedMicrophone}" IsEnabled="{Binding !IsRecording}" HorizontalAlignment="Stretch">
                                            <ComboBox.ItemTemplate><DataTemplate DataType="models:AudioDevice"><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding MicLevel}" Height="6" CornerRadius="3" Foreground="#10B981" Background="#1E293B"/>
                                    </StackPanel>
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="System Loopback" FontSize="12" Foreground="#94A3B8"/>
                                        <ComboBox ItemsSource="{Binding DesktopSources}" SelectedItem="{Binding SelectedDesktopSource}" IsEnabled="{Binding !IsRecording}" HorizontalAlignment="Stretch">
                                            <ComboBox.ItemTemplate><DataTemplate DataType="models:AudioDevice"><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding DesktopLevel}" Height="6" CornerRadius="3" Foreground="#38BDF8" Background="#1E293B"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Row="2" Spacing="12">
                                <Button Classes="primary" Command="{Binding StartRecordingCommand}" IsEnabled="{Binding !IsRecording}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="🔴"/><TextBlock Text="Start Recording"/></StackPanel>
                                </Button>
                                <Button Classes="danger" Command="{Binding StopRecordingCommand}" IsEnabled="{Binding IsRecording}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="⏹️"/><TextBlock Text="Stop &amp; Process"/></StackPanel>
                                </Button>
                                <Button Classes="neutral" Command="{Binding SelectAndProcessVideoCommand}" IsEnabled="{Binding !IsRecording}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="📁"/><TextBlock Text="Import Media"/></StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Recap Viewer -->
                        <Grid Grid.Column="2" RowDefinitions="Auto, *">
                            <TextBlock Grid.Row="0" Text="Meeting Summary" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,16"/>
                            <Border Grid.Row="1" Background="{StaticResource BackgroundCardBrush}" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBox Text="{Binding RecapText}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                                             Background="Transparent" BorderThickness="0" Foreground="#E2E8F0" FontSize="14" LineHeight="24"
                                             FontFamily="Consolas, Courier New, monospace" Padding="20"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- 2. HISTORY VIEW -->
                <Grid IsVisible="{Binding IsHistoryVisible}" ColumnDefinitions="320, 24, *">
                    <!-- History List -->
                    <Grid Grid.Column="0" RowDefinitions="Auto, *">
                        <TextBlock Grid.Row="0" Text="Past Meetings" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,16"/>
                        <Border Grid.Row="1" Background="{StaticResource BackgroundCardBrush}" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="8">
                            <ListBox ItemsSource="{Binding PastMeetings}" SelectedItem="{Binding SelectedMeeting}" Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="models:MeetingRecord">
                                        <Grid RowDefinitions="Auto, Auto">
                                            <TextBlock Grid.Row="0" Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" Foreground="#E2E8F0" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Row="1" Text="{Binding Date, StringFormat='{}{0:f}'}" FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>

                    <!-- History Detail -->
                    <Grid Grid.Column="2" RowDefinitions="Auto, *">
                        <Border Grid.Row="0" Background="{StaticResource BackgroundCardBrush}" BorderBrush="#1E293B" BorderThickness="1"
                                CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="EXPORT" FontSize="10" FontWeight="Bold" Foreground="#64748B" LetterSpacing="1.2" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button Classes="action" Command="{Binding ExportTranscriptionCommand}"><StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="📄"/><TextBlock Text="Script"/></StackPanel></Button>
                                <Button Classes="action" Command="{Binding ExportAiRecapCommand}"><StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="🗒️"/><TextBlock Text="Recap"/></StackPanel></Button>
                                <Separator Width="1" Background="#1E293B" Margin="8,0"/>
                                <Button Classes="action" Command="{Binding TranslateRecapCommand}"><StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="🌐"/><TextBlock Text="Translate"/></StackPanel></Button>
                                <Button Classes="action" Command="{Binding ExportTranslationCommand}"><StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="💾"/><TextBlock Text="Translation"/></StackPanel></Button>
                            </StackPanel>
                        </Border>
                        
                        <Border Grid.Row="1" Background="{StaticResource BackgroundCardBrush}" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBox Text="{Binding RecapText}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                                         Background="Transparent" BorderThickness="0" Foreground="#E2E8F0" FontSize="14" LineHeight="24"
                                         FontFamily="Consolas, Courier New, monospace" Padding="20"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <!-- 3. SETTINGS VIEW -->
                <Grid IsVisible="{Binding IsSettingsVisible}" RowDefinitions="Auto, *">
                    <TextBlock Grid.Row="0" Text="Application Settings" FontSize="20" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,16"/>
                    <Border Grid.Row="1" Background="{StaticResource BackgroundCardBrush}" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="24" MaxWidth="600" HorizontalAlignment="Left">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="24">
                                
                                <StackPanel Spacing="8">
                                    <TextBlock Text="AI PROVIDER" FontSize="11" FontWeight="Bold" Foreground="#64748B" LetterSpacing="1"/>
                                    <ComboBox ItemsSource="{Binding Settings.AvailableProviders}" SelectedItem="{Binding Settings.SelectedProvider}" HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <StackPanel Spacing="8">
                                    <TextBlock Text="API CONFIGURATION" FontSize="11" FontWeight="Bold" Foreground="#64748B" LetterSpacing="1"/>
                                    <StackPanel Spacing="12">
                                        <TextBox Text="{Binding Settings.ApiUrl}" PlaceholderText="http://local-server:11434 (API URL)"/>
                                        <TextBox Text="{Binding Settings.ApiKey}" PasswordChar="*" PlaceholderText="API Key (Not required for Ollama)" IsEnabled="{Binding Settings.IsApiKeyRequired}"/>
                                        <ComboBox ItemsSource="{Binding Settings.AvailableModels}" SelectedValue="{Binding Settings.SelectedModel}" IsEditable="True" HorizontalAlignment="Stretch" PlaceholderText="Select or type model name"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="8">
                                    <TextBlock Text="LANGUAGES" FontSize="11" FontWeight="Bold" Foreground="#64748B" LetterSpacing="1"/>
                                    <StackPanel Spacing="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Recording Language (STT)" FontSize="12" Foreground="#94A3B8"/>
                                            <ComboBox ItemsSource="{Binding Settings.AvailableLangs}" SelectedItem="{Binding Settings.RecLang}" HorizontalAlignment="Stretch">
                                                <ComboBox.ItemTemplate><DataTemplate DataType="models:AppLang"><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Output Language (LLM recap)" FontSize="12" Foreground="#94A3B8"/>
                                            <ComboBox ItemsSource="{Binding Settings.AvailableLangs}" SelectedItem="{Binding Settings.OutLang}" HorizontalAlignment="Stretch">
                                                <ComboBox.ItemTemplate><DataTemplate DataType="models:AppLang"><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="8">
                                    <TextBlock Text="STORAGE" FontSize="11" FontWeight="Bold" Foreground="#64748B" LetterSpacing="1"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBox Grid.Column="0" Text="{Binding Settings.ExportFolderPath}" PlaceholderText="Export output directory..." IsReadOnly="True" Margin="0,0,8,0"/>
                                        <Button Grid.Column="1" Classes="action" Command="{Binding Settings.SelectFolderCommand}" Content="Browse…"/>
                                    </Grid>
                                </StackPanel>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>
